<% layout("layouts/boilerplate") %>
<div class="row mt-3">
  <div class="col-8 offset-2"><h2>SingUp on WounderLust</h2>  </div>
        <div class="col-8 offset-2">
            <form action="/singup" method="post" class="needs-validation" novalidate>
                <div class="mb-3">
          <label for="username" class="form-label">Username:</label>
            <input type="text" name="username"required class="form-control" id="username">
            <div class="valid-feedback">Username looks goods</div>
        </div>
         <div class="mb-3">
          <label for="email" class="form-label">email:</label>
            <input type="email" name="email" id="email" required class="form-control" id="email">
            </div>
             <div class="mb-3">
          <label for="password" class="form-label">Password:</label>
            <input type="password" name="password" id="password" required class="form-control" id="password">
            </div>
            <button class="btn btn-success">singUp</button>
            </form>
     </div>
</div>
